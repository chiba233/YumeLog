{
  "name": "yume-log",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "pnpm run test:dsl",
    "predev": "node ./scripts/patch-vite-ssg.mjs",
    "dev": "vite",
    "host": "pnpm run dev --host",
    "prebuild": "node ./scripts/patch-vite-ssg.mjs",
    "build": "vue-tsc --noEmit && vite-ssg build && pnpm run test:ssg-dist",
    "build:local": "pnpm run test:dsl && pnpm run build",
    "build:client": "vite build",
    "preview": "vite preview",
    "build-only": "pnpm run test:dsl && vite-ssg build && pnpm run test:ssg-dist",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "test:dsl": "node --import ./tests/register-alias.mjs ./tests/run-dsl-tests.ts",
    "test:ssg-dist": "node --import ./tests/register-alias.mjs ./tests/postBuildSsg.test.ts",
    "test-build-dist": "npx serve dist -s",
    "postinstall": "node ./scripts/patch-vite-ssg.mjs"
  },
  "dependencies": {
    "@unhead/vue": "^2.1.12",
    "@vicons/fluent": "^0.13.0",
    "@vicons/ionicons5": "^0.13.0",
    "@vicons/material": "^0.13.0",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.6",
    "dayjs": "^1.11.20",
    "p-limit": "^7.3.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "naive-ui": "^2.44.1",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "sass-embedded": "^1.98.0",
    "shiki": "^4.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.1",
    "vite-ssg": "^28.3.0",
    "vite-svg-loader": "^5.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6",
    "wait-on": "^9.0.4"
  }
}
