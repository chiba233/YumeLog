{
  "name": "yume-log",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "host": "pnpm run dev --host",
    "build": "vue-tsc --noEmit && vite build && pnpm run ssg",
    "ssg": "concurrently -k --success first \"npx serve dist -s -l 14514\" \"wait-on http://localhost:14514 && vite-ssg build\"",
    "build:client": "vite build",
    "preview": "vite preview",
    "build-only": "vite-ssg build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "test-build-dist": "npx serve dist -s"
  },
  "dependencies": {
    "@unhead/vue": "^2.1.10",
    "@vicons/fluent": "^0.13.0",
    "@vicons/ionicons5": "^0.13.0",
    "@vicons/material": "^0.13.0",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.6",
    "dayjs": "^1.11.19",
    "js-yaml": "^4.1.1",
    "p-limit": "^7.3.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.9.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "naive-ui": "^2.44.1",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "sass-embedded": "^1.97.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-ssg": "^28.3.0",
    "vite-svg-loader": "^5.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5",
    "wait-on": "^9.0.4"
  }
}
