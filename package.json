{
  "name": "yume-log",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "predev": "node ./scripts/patch-vite-ssg.mjs",
    "lint": "eslint . --ext .ts,.tsx,.vue,.js,.mjs,.cjs --fix --cache",
    "typecheck": "vue-tsc --noEmit",
    "test": "pnpm run test:dsl",
    "test:dsl": "node --import ./tests/register-alias.mjs ./tests/run-dsl-tests.ts",
    "test:ssg": "node --import ./tests/register-alias.mjs ./tests/postBuildSsg.test.ts",
    "verify": "pnpm run lint && pnpm run test",
    "verify:build": "pnpm run verify && pnpm run build",
    "prebuild": "node ./scripts/patch-vite-ssg.mjs",
    "build": "pnpm run typecheck && vite-ssg build && pnpm run test:ssg",
    "build:client": "vite build",
    "preview": "vite preview",
    "preview:dist": "npx serve dist -s",
    "postinstall": "node ./scripts/patch-vite-ssg.mjs"
  },
  "dependencies": {
    "@unhead/vue": "^2.1.12",
    "@vicons/fluent": "^0.13.0",
    "@vicons/ionicons5": "^0.13.0",
    "@vicons/material": "^0.13.0",
    "@vueuse/core": "^14.2.1",
    "dayjs": "^1.11.20",
    "p-limit": "^7.3.0",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "yume-dsl-rich-text": "^1.1.1",
    "yume-dsl-shiki-highlight": "^2.0.0"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "naive-ui": "^2.44.1",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "sass-embedded": "^1.99.0",
    "shiki": "^4.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "unplugin-vue-components": "^31.1.0",
    "vite": "^8.0.3",
    "vite-ssg": "^28.3.0",
    "vite-svg-loader": "^5.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6",
    "wait-on": "^9.0.4"
  }
}
